// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // e.g., ADMIN, THERAPIST, USER
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  payments      Payment[]
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  age       Int?
  notes     String?
  
  fechaNacimiento String?
  sexo            String?
  fechaIngreso    String?
  estatus         String? @default("Activo")
  origen          String? @default("Google")
  medicoTratante  String?
  escuela         String?

  madreNombre     String?
  padreNombre     String?
  otrosNombre     String?
  madreContacto   String?
  padreContacto   String?
  otrosContacto   String?
  principalMadre  Boolean @default(false)
  principalPadre  Boolean @default(false)
  principalOtros  Boolean @default(false)
  correoPrincipal String?

  alergias        Boolean @default(false)
  crisis          Boolean @default(false)
  convulsiones    Boolean @default(false)
  sensibilidad    Boolean @default(false)
  riesgoFuga      Boolean @default(false)
  noSepara        Boolean @default(false)
  otrasAlertas    Boolean @default(false)

  reglamentoFirmado     Boolean @default(false)
  consentimientoFirmado Boolean @default(false)

  observacionesAdmin    String?
  precioTerapia         String?
  metodoPago            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  Session[]
  payments  Payment[]
}
model Session {
  id          String   @id @default(cuid())
  date        DateTime
  status      String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  notes       String?
  
  therapistId String
  therapist   User     @relation(fields: [therapistId], references: [id])
  
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  amount      Float
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED
  method      String?  // CASH, CARD, TRANSFER
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSettings {
  id                    Int      @id @default(1)
  allowTherapistEdit    Boolean  @default(true)
  referenceKeys         String   @default("")
  updatedAt             DateTime @updatedAt
}

model OperationalExpense {
  id        String   @id @default(cuid())
  month     String   // YYYY-MM
  label     String
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, label])
}
